  "bugs": {
    "url": "https://github.com/rizadt19/jules/issues"
  },
  "homepage": "https://github.com/rizadt19/jules#readme",
  "devDependencies": {
    "concurrently": "^8.2.2" # Using a more recent version
  }
}
